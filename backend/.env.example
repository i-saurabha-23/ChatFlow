PORT=3000
MONGODB_URI=mongodb://localhost:27017
MESSAGE_ENCRYPTION_KEY=replace_with_64_char_hex_key
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=7d
# Comma-separated OAuth client IDs allowed to sign in (web + android client IDs)
GOOGLE_CLIENT_IDS=your_web_client_id.apps.googleusercontent.com
